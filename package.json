{
  "name": "aichestra",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "db:migrate": "node scripts/db/migrate.mjs",
    "dev": "pnpm --filter @aichestra/api dev",
    "lint": "node scripts/lint.mjs",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "@aichestra/adapters": "workspace:*",
    "@aichestra/api": "workspace:*",
    "@aichestra/auth": "workspace:*",
    "@aichestra/core": "workspace:*",
    "@aichestra/db": "workspace:*",
    "@aichestra/deployment-readiness": "workspace:*",
    "@aichestra/git-adapter": "workspace:*",
    "@aichestra/improvement": "workspace:*",
    "@aichestra/llm-gateway": "workspace:*",
    "@aichestra/mcp-gateway": "workspace:*",
    "@aichestra/policy": "workspace:*",
    "@aichestra/registry": "workspace:*",
    "@aichestra/runner": "workspace:*",
    "@aichestra/security": "workspace:*",
    "@aichestra/shared": "workspace:*",
    "@aichestra/worker": "workspace:*",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "volta": {
    "node": "24.15.0"
  }
}
